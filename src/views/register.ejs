<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/meta.ejs", { title: "Register" }) -%>
  </head>
  <body>
    <h1>Register</h1>
    <form action="/auth/register" method="POST">
      <div class="form-control">
        <label for="name">Name</label>
        <input type="text" name="name" id="name" value="prefilledUser" />
      </div>
      <div class="form-control">
        <label for="email">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          value="prefilled@gmail.com"
        />
      </div>
      <div class="form-control">
        <label for="password">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          value="testing123"
        />
      </div>
      <button type="submit">Register!</button>
    </form>
  </body>
</html>
